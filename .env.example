# Entra ID (Azure AD) app registration — single tenant (salwangurgaon.com), delegated permissions.
CLIENT_ID=17c09f6d-dfb3-451f-85f1-96e40d048038
TENANT_ID=4fae5689-bd93-4e1a-99ec-4da629fd0416

# Create this in Azure Portal -> App registrations -> your app -> Certificates & secrets
# -> New client secret. Copy the VALUE (not the Secret ID) here.
CLIENT_SECRET=replace-with-your-client-secret-value

# Must exactly match a Redirect URI configured on the app registration
# (Platform: Web) in Azure Portal -> Authentication.
REDIRECT_URI=http://localhost:8000/auth/callback

# Fernet key used to encrypt refresh tokens at rest. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=replace-with-a-generated-fernet-key

# Shared secret that guards the /tasks/sync and /tasks/daily-report endpoints.
# In production the GitHub Actions cron presents this in the X-Task-Token header.
# Generate any long random string, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
# Leave blank locally if you rely on the in-process scheduler instead.
TASK_TRIGGER_TOKEN=

# "true" (default) runs the in-process APScheduler — convenient for local dev.
# Set "false" in production, where an external cron drives /tasks/* instead.
ENABLE_INTERNAL_SCHEDULER=true
